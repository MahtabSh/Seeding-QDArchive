# ─────────────────────────────────────────────────────────────
# QDArchive — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Pipeline outputs ──────────────────────────────────────────
# Resume/progress state
*.progress.json

# Log files
pipeline.log
*.log

# ── Credentials ───────────────────────────────────────────────
# Environment variable files
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / type checking
.mypy_cache/
.dmypy.json

# ── Tooling ───────────────────────────────────────────────────
.claude/

# ── Editors & OS ──────────────────────────────────────────────
# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── LaTeX (if editing docs locally) ──────────────────────────
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc
docs/*.fls
docs/*.fdb_latexmk
docs/*.synctex.gz
docs/*.bbl
docs/*.blg

# Keep the compiled PDF and source in the repo
!docs/*.pdf
!docs/*.tex

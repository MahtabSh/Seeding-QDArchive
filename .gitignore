# ─────────────────────────────────────────────────────────────
# QDArchive — .gitignore
# ─────────────────────────────────────────────────────────────

# ── Database files (too large for git, managed separately) ────
*.db
*.db-shm
*.db-wal
# Submission DB tracked via git-lfs
!23692652-sq26-classification.db

# ── Pipeline outputs ──────────────────────────────────────────
# Resume/progress state (e.g. classify_isic.progress.json.mistral)
*.progress.json
*.progress.json.*

# Log files
pipeline.log
*.log

# ── Caches ────────────────────────────────────────────────────
# ChromaDB vector store
.chroma_db/

# Google Drive downloaded file snippets
.file_cache/

# Jupyter auto-save checkpoints
.ipynb_checkpoints/

# SQLite WAL/shared-memory temp files
*.db-shm
*.db-wal

# ── Generated reports & exports ───────────────────────────────
# Methodology and classification reports — local only, not tracked in git
23692652-sq26-classification-methodology.md
23692652-sq26-classification-methodology.docx
23692652-sq26-classification-methodology.pdf
23692652-sq26-classification-report.docx
23692652-sq26-classification-report.pdf
23692652-sq26-report-repo*.docx
23692652-sq26-report-repo*.pdf

# Word / Excel / PowerPoint outputs
Classification_Report.docx
QDArchive_*.docx
QDArchive_*.xlsx
QDArchive_*.pptx

# PDF reports generated by scripts
QDArchive_*.pdf
comparison_report.pdf
report_isic_histograms.pdf

# CSV exports generated by scripts
report_distributions.csv
report_distributions_overview.csv

# ── Credentials ───────────────────────────────────────────────
# Environment variable files
.env
.env.*
!.env.example

# Google Drive API credentials and OAuth tokens — never commit these
credentials.json
token.pickle
gdrive_upload.py

# Old / working databases — only 23692652-sq26.db is the canonical output
metadata.sqlite
metadata.sqlite-shm
metadata.sqlite-wal
prev-schema/

# Fine-tuned model weights (large binaries, not tracked in git)
models/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# mypy / type checking
.mypy_cache/
.dmypy.json

# ── Tooling ───────────────────────────────────────────────────
.claude/

# ── Editors & OS ──────────────────────────────────────────────
# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── LaTeX (if editing docs locally) ──────────────────────────
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc
docs/*.fls
docs/*.fdb_latexmk
docs/*.synctex.gz
docs/*.bbl
docs/*.blg

# Keep the compiled PDF and source in the repo
!docs/*.pdf
!docs/*.tex
